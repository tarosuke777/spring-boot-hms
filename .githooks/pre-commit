#!/bin/sh

# ステージングされた変更ファイル（Java、HTML、CSS、JSなどすべて）を取得
staged_files=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -n "$staged_files" ]; then
    echo "Spotlessでプロジェクト全体のコードを自動整形中..."
    
    # 変更されたファイルだけを対象にSpotlessを実行（超高速）
    ./gradlew spotlessApply -PspotlessFiles="$(echo "$staged_files" | paste -sd "," -)"
    
    # 整形されたファイルを再ステージング
    echo "$staged_files" | xargs git add
fi