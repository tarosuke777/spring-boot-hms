#!/bin/sh

# --- 1. Javaの処理 ---
java_files=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.java$')
if [ -n "$java_files" ]; then
    JAR_PATH="$HOME/.google-java-format/google-java-format-1.35.0-all-deps.jar"
    if [ -f "$JAR_PATH" ]; then
        echo "Javaファイルを自動整形中..."
        java -jar "$JAR_PATH" --replace $java_files
        git add $java_files
    else
        echo "【エラー】JavaのJARファイルが見つかりません: $JAR_PATH"
        exit 1
    fi
fi

# --- 2. HTML/CSS/JSの処理 ---
web_files=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(html|css|js)$')
if [ -n "$web_files" ]; then
    echo "HTML/CSS/JSファイルを自動整形中..."
    ./node_modules/.bin/prettier --write $web_files
    git add $web_files
fi